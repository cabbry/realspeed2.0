<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RealSpeed2.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RealSpeed2"
    Shell.FlyoutBehavior="Disabled"    
    >

    <ShellContent
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage"
        >
    </ShellContent>

    <Shell.TitleView>
        <Label Text="Real Speed 2.0"  Style="{StaticResource MainTile}"></Label>
    </Shell.TitleView>

</Shell>
